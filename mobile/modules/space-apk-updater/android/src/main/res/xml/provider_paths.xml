<?xml version="1.0" encoding="utf-8"?>
<!--
  Scoped paths for Package Installer handoff (Android 7.0+).
  APKs land in cache/ or getExternalFilesDir() — never shared storage.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
  <cache-path name="apk_cache" path="." />
  <files-path name="apk_files" path="." />
  <external-files-path name="apk_external_files" path="." />
  <external-cache-path name="apk_external_cache" path="." />
</paths>
