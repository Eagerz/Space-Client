# Copy to .env and fill with Stripe Dashboard test keys
PORT=8787

# Stripe secret key (sk_test_... in Test mode) — NEVER put this in Electron
STRIPE_SECRET_KEY=sk_test_replace_me

# Webhook signing secret from `stripe listen` or Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional: Dashboard Price IDs (price_...) for credit packs & Space+
# If omitted, credit packs use dynamic EUR price_data (still secure via Checkout)
STRIPE_PRICE_CREDITS_500=
STRIPE_PRICE_CREDITS_1000=
STRIPE_PRICE_CREDITS_2500=
STRIPE_PRICE_CREDITS_5000=
STRIPE_PRICE_SPACEPLUS_MONTHLY=
STRIPE_PRICE_SPACEPLUS_ANNUAL=

# Where Stripe sends the shopper after Checkout
STRIPE_SUCCESS_URL=https://github.com/Eagerz/space-client#payment-success
STRIPE_CANCEL_URL=https://github.com/Eagerz/space-client#payment-cancelled

# Comma-separated allowed origins (optional)
# CORS_ORIGIN=http://localhost:3457

# Signed JWT for Stardust progression sync + Cosmic Shop claims (launcher ↔ API)
# MUST match PROGRESSION_JWT_SECRET in the Electron main process environment
PROGRESSION_JWT_SECRET=replace-with-long-random-secret

# Space Bridge relay (optional UDP tunnel fallback when UPnP fails)
# SPACE_BRIDGE_RELAY_HOST=relay.spaceclient.app
# SPACE_BRIDGE_RELAY_PORT=19132

# Discord status / incident webhook (Incoming Webhook URL — treat as secret)
# Leave empty to disable Discord posts. See docs/DISCORD_ALERTS.md
DISCORD_STATUS_WEBHOOK_URL=
# Set to false to mute all Discord alerts even if webhook is set
DISCORD_ALERTS_ENABLED=true
# Health-check interval in ms (default 60000)
# DISCORD_STATUS_INTERVAL_MS=60000

# --- AI crash recovery — never put keys in Electron ---
# Provider: auto | openai | gemini | local  (auto picks gemini > openai > local)
# CRASH_AI_PROVIDER=auto
# Leave both keys empty to use local heuristics only
OPENAI_API_KEY=
# OPENAI_CRASH_MODEL=gpt-4o-mini
GEMINI_API_KEY=
# GEMINI_CRASH_MODEL=gemini-2.0-flash

# --- Discord staff bot (crash reports + changelogs + tickets) ---
# Create a bot at https://discord.com/developers/applications
# Invite with bot + applications.commands. See docs/DISCORD_BOT.md
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Password for /setup-server (required string option) — set locally — never commit
DISCORD_SETUP_PASSWORD=
DISCORD_STAFF_CHANNEL_ID=
DISCORD_STAFF_ANNOUNCEMENTS_CHANNEL_ID=
DISCORD_TODOS_CHANNEL_ID=
DISCORD_CHANGELOG_CHANNEL_ID=
DISCORD_STATUS_CHANNEL_ID=
# Public reviews panel channel (⭐│reviews)
DISCORD_REVIEWS_PANEL_CHANNEL_ID=
# Where submitted reviews are posted (⭐│staff-reviews)
DISCORD_REVIEWS_CHANNEL_ID=
DISCORD_SUGGESTIONS_CHANNEL_ID=
DISCORD_ACCEPTED_SUGGESTIONS_CHANNEL_ID=
# Public tickets panel (🎫│tickets)
DISCORD_TICKETS_PANEL_CHANNEL_ID=
# Optional legacy: SUPPORT category (typed ticket cats preferred)
DISCORD_TICKET_CATEGORY_ID=
# Typed ticket categories (private)
DISCORD_TICKET_CAT_GENERAL_ID=
DISCORD_TICKET_CAT_REFUNDS_ID=
DISCORD_TICKET_CAT_BUG_ID=
DISCORD_TICKET_CAT_MANAGER_ID=
DISCORD_TICKET_CAT_PURCHASE_ID=
# Roles (created/updated by /setup-server)
DISCORD_STAFF_ROLE_ID=
DISCORD_ROLE_HELPER_ID=
DISCORD_ROLE_MOD_ID=
DISCORD_ROLE_SRMOD_ID=
DISCORD_ROLE_SRADMIN_ID=
DISCORD_ROLE_EAGERZ1_ID=
DISCORD_ROLE_MANAGER_ID=
DISCORD_ROLE_DEVELOPERS_ID=
# Optional: extra role allowed to /changelog (Manage Server also works)
# DISCORD_ADMIN_ROLE_ID=

# --- Egrz staff dashboard (http://localhost:8787/egrz/) ---
# Discord Application → OAuth2 → redirect: {EGRZ_PUBLIC_URL}/api/staff/auth/callback
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
EGRZ_SESSION_SECRET=
EGRZ_PUBLIC_URL=http://localhost:8787
# Rich Presence while Egrz is open (Discord desktop must be running on this PC)
# EGRZ_DISCORD_RPC=true
# Optional art keys uploaded under Discord Dev Portal → Rich Presence → Art Assets
# EGRZ_RPC_LARGE_IMAGE=apex

# --- Space Bedrock Android in-app updates ---
# Clients fetch GET /v1/mobile/android-update.json (also mounted at /api/v1/...)
# Prefer a full JSON blob or an upstream URL to the CI-published android-update.json.
# MOBILE_ANDROID_UPDATE_JSON={"android-arm64":{"version":"1.0.1","versionCode":10001,"apkUrl":"https://..."}}
# MOBILE_ANDROID_UPDATE_URL=https://github.com/Eagerz/space-client/releases/download/mobile-v1.0.1/android-update.json
# Or synthesize:
# MOBILE_ANDROID_APK_URL=https://github.com/Eagerz/space-client/releases/download/mobile-v1.0.1/Space-Bedrock-1.0.1-android.apk
# MOBILE_ANDROID_VERSION=1.0.1
# MOBILE_ANDROID_VERSION_CODE=10001
# MOBILE_ANDROID_APK_SHA256=
